# MCP Server Configuration
# Copy to .env and adjust as needed.

# Logging verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Maximum file size allowed for read_file_summary and csv_stats (megabytes)
MAX_FILE_SIZE_MB=10

# Maximum response body size for fetch_url (kilobytes)
MAX_FETCH_SIZE_KB=500

# Comma-separated list of root directories that file tools are allowed to access.
# Add any directories you want Claude to be able to search or read.
ALLOWED_DIRECTORIES=/home,/tmp,/mnt
